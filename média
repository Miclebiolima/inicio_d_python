#calcular media de alunos com nome

def media(n1, n2):
    return (n1 + n2) / 2

alunos = []  #lista a ser preenchida

numalunos = int(input("quantos alunos tem na turma : "))
for i in range(numalunos):
    #coloca o nome do aluno
    nome = input(f"digite o nome do aluno {i + 1} : ")

    #coloca a primeira nota
    n1 = float(input("digite a primeira nota : "))

    #colocar a segunda nota
    n2 = float(input("digite a segunda nota : "))

    #lista dos resultados com a media/resultado final
    alunos.append((nome, n1, n2, media(n1, n2)))

    #resultados finais
for aluno in alunos:
    print(f"aluno: {nome} nota 1 {n1} nota 2 {n2} nota final {(n1 + n2) / 2 }")
