cont = 1
QTDALUNOS = 2

#abrir inicio do ciclo
while True:
print("Vamos calcular a nota do Aluno:", cont)
#adicionar nota 1, 2 e 3
nota1 = float(input("primeira nota :"))
nota2 = float(input("segunda nota :"))
nota3 = float(input("terceira nota :"))
#calcular a média de cada aluno
media = (nota1 + nota2 + nota3) / 3
print(f"A nota do Aluno: {cont} é {media}")
cont = cont + 1
#condição de parar o ciclo
if cont > QTDALUNOS:
break
